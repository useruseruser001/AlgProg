<Window x:Class="Country.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Country"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GridSplitter Grid.Column="1" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="3"/>

        <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="3" ShowsPreview="False" Grid.ColumnSpan="3"/>
        <StackPanel Grid.Column="0" Grid.Row="0">
            <Button Background="White" Height="71"/>
            <Button Background="Blue" Height="71"/>
            <Button Background="Red" Height="71"/>
        </StackPanel>
        <Grid Grid.Column="0" Grid.Row="1" Grid.RowSpan="2">

            <Button Grid.Row="0" Grid.Column="0" Background="Red" Margin="0,0,294,134" />
            <Button Background="Red" Margin="129,0,0,134" />
            <Button Grid.Column="0" Background="Red" Margin="0,109,294,0" />
            <Button Background="Red" Margin="129,109,0,0" />
        </Grid>




    </Grid>
</Window>
